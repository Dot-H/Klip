# Local development environment configuration.
# Used by `pnpm dev` / `pnpm dx` via dotenv-cli to override DATABASE_URL
# so migrations/seed hit the local Postgres container (docker-compose.dev.yml)
# instead of the Neon URLs that Vercel CLI writes into .env.development.local.

DATABASE_URL="postgresql://postgres:postgres@localhost:5434/klip_dev"
